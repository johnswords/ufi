# UFI MedEnt — Environment Configuration
# Copy to .env and adjust values for your environment.

# ─── Web Demo Server ──────────────────────────────────────────────────────────
PORT=3000

# ─── Ollama (Local LLM) ──────────────────────────────────────────────────────
# Model for clinical criteria extraction and note rewriting.
# Requires Ollama running locally: https://ollama.com
OLLAMA_MODEL=glm-4.7-flash:latest
OLLAMA_BASE_URL=http://localhost:11434

# ─── Medent EHR Integration (on-prem agent only) ─────────────────────────────
# Obtain a registration ID at https://medentmobile.com/mapi/register/
# These are only needed for the on-prem agent, not the web demo.
# MAPI_REGISTRATION_ID=
# MAPI_BASE_URL=https://www.medentmobile.com/mapi/services
